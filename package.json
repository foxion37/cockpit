{
	"name": "@code-yeongyu/cockpit",
	"version": "0.1.0",
	"description": "A slim, auto-updated Markdown cockpit for Codex work sessions.",
	"type": "module",
	"packageManager": "npm@11.12.1",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/foxion37/cockpit.git"
	},
	"homepage": "https://github.com/foxion37/cockpit#readme",
	"bugs": {
		"url": "https://github.com/foxion37/cockpit/issues"
	},
	"keywords": [
		"codex",
		"cockpit",
		"markdown-dashboard",
		"agent-workflow",
		"progress-tracking"
	],
	"bin": {
		"cockpit": "./dist/cli.js"
	},
	"files": [
		"dist",
		"assets",
		"skills",
		"README.md",
		"LICENSE",
		"NOTICE"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest --run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome check package.json tsconfig.json tsconfig.build.json vitest.config.ts src test",
		"lint:fix": "biome check --write package.json tsconfig.json tsconfig.build.json vitest.config.ts src test",
		"check": "tsc --noEmit && npm run lint && npm run build",
		"prepare": "npm run build"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/node": "^25.7.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
